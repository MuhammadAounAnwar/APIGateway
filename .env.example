# APIGateway — Environment Variables
# Copy to .env and fill in before running

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8762

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Eureka ─────────────────────────────────────────────────────────────────────
EUREKA_ZONE=http://localhost:8761/eureka

# ── Firebase App Check (leave blank to disable — safe for dev) ─────────────────
# Same service account JSON used by AuthClient (same Firebase project)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Rate Limits ─────────────────────────────────────────────────────────────────
# Requests per minute per IP (public routes)
PUBLIC_IP_RATE_LIMIT=50
# Requests per minute per authenticated user
PER_USER_RATE_LIMIT=200
